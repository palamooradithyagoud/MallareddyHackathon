{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "app/main.py"
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(assets/.*|.*\\.(svg|png|jpg|jpeg|ico|json|js|css))",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend",
                "path": "/index.html"
            }
        }
    ]
}
